#include<iostream>
using namespace std;
int gct(int m,int n){
	if(n==0)
	return m;
	return gct(n,m%n);
}
int main(){
	cout<<"1:"<<gct(20,8)<<endl;
	cout<<"2:"<<gct(36,64)<<endl;
	
	
	
return 0;
}






#include<iostream>
using namespace std;
void reserve(int array[],int size){
	int i,k,m;
	for(i=0,k=size-1;i<k;i++,k--){
		m=array[i];
		array[i]=array[k];
		array[k]=m;
		
	}
}
int main(){
	int A[5]={1,2,3,4,5},m,i;
	m=sizeof (A)/sizeof(A[0]);
	reserve(A,m);
	for(i=0;i<m;i++){
	cout<<A[i];	
		
	}
	return 0;
	
}




int getMAx(int *array,int size){
	int m,i;
	m=0;
	for(i=0;i<size;i++){
		if(m<array[i])
		m=array[i];

	}return m;
}
#include<iostream>
using namespace std;
int main(){
	int A[5]={1,2,3,4,5},m;
	m=sizeof (A)/sizeof(A[0]);
cout<<getMAx(A,m)<<endl;
