#include<iostream>
using namespace std;
int *getDiagonal(int **matrix,int n){
	int *diag=new int [2*n-1];
	int count=0;
	for(int i=0;i<n;i++){
		for(int j=0;j<n;j++){
			if(i==j||j+i==n-1){
				diag[count++]=matrix[i][j];
			}
		}
	}
	return diag;
	
	}
